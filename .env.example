# PostgreSQL via Docker (port 5433 — avoids conflict with system Postgres on 5432)
DATABASE_URL=postgresql+psycopg://datads:datads@localhost:5433/datads

# SQLite fallback (no Docker required):
# DATABASE_URL=sqlite:///./datads.db
API_BASE_URL=https://datads-mock-ad-apis.happygrass-47d99234.germanywestcentral.azurecontainerapps.io
FACEBOOK_API_KEY=facebook_test_key_123
GOOGLE_TOKEN=google_test_token_456
TIKTOK_TOKEN=tiktok_test_token_789

# Browser origins for Live API Playground (comma-separated). Add your deployed frontend URL.
# CORS_ORIGINS=http://localhost:8080,http://localhost:5173,https://your-frontend.pages.dev

# AWS ingestion worker (optional — set after terraform apply)
AWS_REGION=eu-central-1
SQS_QUEUE_URL=
SQS_DLQ_URL=
